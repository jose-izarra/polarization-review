{
  "description": "Local model size ablation — same fake items assessed by Ollama Gemma 3 models of increasing parameter count",
  "model_family": "gemma3",
  "scenarios": [
    "fake_polarized_general",
    "fake_moderate_general",
    "fake_neutral_general"
  ],
  "runs": 1,
  "out_dir": "studies/local_model_size/results",
  "ollama_host": "http://localhost:11434",
  "model_families": {
    "gemma3": {
      "description": "Google Gemma 3 family — efficient open models at 1B, 4B, 12B, 27B",
      "models": [
        {
          "label": "gemma3-1b",
          "model_id": "ollama/gemma3:1b",
          "params_billions": 1.0,
          "pull_name": "gemma3:1b"
        },
        {
          "label": "gemma3-4b",
          "model_id": "ollama/gemma3:4b",
          "params_billions": 4.0,
          "pull_name": "gemma3:4b"
        },
        {
          "label": "gemma3-12b",
          "model_id": "ollama/gemma3:12b",
          "params_billions": 12.0,
          "pull_name": "gemma3:12b"
        }
      ]
    }
  }
}
